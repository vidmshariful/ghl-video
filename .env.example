# GHL Video native checkout: environment variables.
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored; NEVER commit real keys. LIVE secret keys go only in the
# Vercel dashboard, never in this repo.

# --- Site ---------------------------------------------------------------
# Absolute origin, used to build return URLs and the Stripe webhook target.
NEXT_PUBLIC_SITE_URL=https://ghlvideo.com

# --- Stripe (use TEST keys for the whole build; live keys only in Vercel)
# From the website's own Stripe account (the new sub-account under the org,
# NOT the one connected to HighLevel), in Test mode: Developers > API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx   # publishable, safe on the client
STRIPE_SECRET_KEY=sk_test_xxx                    # secret, server only
# Signing secret for the /api/webhooks/stripe endpoint. Created when the
# webhook endpoint is registered (Stripe CLI for local, dashboard for prod).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Supabase -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xdarleyimthsnareuoxl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # publishable, RLS-limited
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # server only; runtime data ops
# Postgres connection string (Session mode, includes password). Only used
# to APPLY migrations/DDL from a trusted shell; not read by the app at runtime.
SUPABASE_DB_URL=postgresql://postgres.xdarleyimthsnareuoxl:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- HighLevel (LeadConnector) API v2 -----------------------------------
# Private Integration token (pit-...), scoped to the website's location.
HIGHLEVEL_API_TOKEN=pit-xxx
HIGHLEVEL_LOCATION_ID=xxx                        # the subaccount's Location ID
HIGHLEVEL_API_VERSION=2021-07-28                 # required Version header
# Opportunity target: filled once we list the pipelines against your location.
HIGHLEVEL_PIPELINE_ID=xxx
HIGHLEVEL_STAGE_ID=xxx                            # the "paid/won" stage
